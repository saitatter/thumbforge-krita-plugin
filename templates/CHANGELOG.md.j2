# Changelog

{%- for version_obj, release in ctx.history.released.items() %}
## {{ version_obj.as_tag() }} ({{ release.tagged_date.strftime("%Y-%m-%d") }})

{%- set category_map = [
  ("✨ Features", ["feat", "feature", "features"]),
  ("🐛 Fixes", ["fix", "fixes", "bug fix", "bug fixes", "bugfix", "bugfixes", "perf", "performance"]),
  ("♻️ Refactors", ["refactor", "refactors", "refactoring"]),
  ("🧰 CI & Build", ["build", "builds", "build system", "ci", "continuous integration", "chore", "chores"]),
  ("📚 Docs", ["doc", "docs", "documentation"]),
  ("🧪 Tests", ["test", "tests", "testing"])
] -%}
{%- set known_types = ["feat", "feature", "features", "fix", "fixes", "bug fix", "bug fixes", "bugfix", "bugfixes", "perf", "performance", "refactor", "refactors", "refactoring", "build", "builds", "build system", "ci", "continuous integration", "chore", "chores", "doc", "docs", "documentation", "test", "tests", "testing"] -%}
{%- set any_changes = namespace(value=false) -%}
{%- set seen_commits = namespace(keys=[]) -%}

{%- for heading, types in category_map %}
{%- set bucket = namespace(items=[]) -%}
{%- for type_name, commits in release["elements"] | dictsort %}
{%- if type_name | lower in types %}
{%- for commit in commits %}
{%- set commit_key = ((commit.scope or "") ~ "|" ~ (commit.descriptions[0] or "")) | lower -%}
{%- if commit_key not in seen_commits.keys %}
{%- set _ = bucket.items.append(commit) -%}
{%- set _ = seen_commits.keys.append(commit_key) -%}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- if bucket.items %}

### {{ heading }}
{%- for commit in bucket.items %}
* {%- if commit.scope %} **{{ commit.scope }}:**{% endif %} {{ commit.descriptions[0] | capitalize }} ([{{ commit.hexsha[:7] }}]({{ commit.hexsha | commit_hash_url }}))
{%- for description in commit.descriptions[1:] %}
  {{ description }}
{%- endfor %}
{%- endfor %}
{%- set any_changes.value = true -%}
{%- endif %}
{%- endfor %}

{%- set other = namespace(items=[]) -%}
{%- for type_name, commits in release["elements"] | dictsort %}
{%- if type_name | lower not in known_types and type_name | lower != "unknown" %}
{%- for commit in commits %}
{%- set commit_key = ((commit.scope or "") ~ "|" ~ (commit.descriptions[0] or "")) | lower -%}
{%- if commit_key not in seen_commits.keys %}
{%- set _ = other.items.append(commit) -%}
{%- set _ = seen_commits.keys.append(commit_key) -%}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- if other.items %}

### 🔧 Other Changes
{%- for commit in other.items %}
* {%- if commit.scope %} **{{ commit.scope }}:**{% endif %} {{ commit.descriptions[0] | capitalize }} ([{{ commit.hexsha[:7] }}]({{ commit.hexsha | commit_hash_url }}))
{%- for description in commit.descriptions[1:] %}
  {{ description }}
{%- endfor %}
{%- endfor %}
{%- set any_changes.value = true -%}
{%- endif %}

{%- if not any_changes.value %}

No user-facing changes in this release.
{%- endif %}

{% endfor %}
